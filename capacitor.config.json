{
  "appId": "com.savertrack.app",
  "appName": "Saver",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#0C0D11",
      "showSpinner": false,
      "fadeOutDuration": 400
    },
    "Keyboard": {
      "resize": "native"
    },
    "LocalNotifications": {
      "presentationOptions": ["badge", "sound", "banner", "list"]
    }
  }
}
